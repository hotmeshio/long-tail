# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=longtail

# NATS
NATS_URL=nats://localhost:4222

# Server
PORT=3000
NODE_ENV=development

# HotMesh
HMSH_LOGLEVEL=info
# Telemetry verbosity: 'info' (default) or 'debug' (all activity spans)
HMSH_TELEMETRY=info

# Auth
JWT_SECRET=your-jwt-secret-here

# OpenAI
OPENAI_API_KEY=xxx

# Honeycomb (OpenTelemetry)
HONEYCOMB_API_KEY=xxx