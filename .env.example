# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5415
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=longtail

# NATS (opt-in — uncomment when using docker-compose.nats.yml)
# NATS_URL=nats://localhost:4222

# Server
PORT=3000
NODE_ENV=development

# HotMesh
HMSH_LOGLEVEL=info
# Telemetry verbosity: 'info' (default) or 'debug' (all activity spans)
HMSH_TELEMETRY=info

# Auth
JWT_SECRET=your-jwt-secret-here

# OpenAI
OPENAI_API_KEY=xxx
ANTHROPIC_API_KEY=yyy

# Honeycomb (OpenTelemetry)
HONEYCOMB_API_KEY=xxx
# Honeycomb UI link generation (for telemetry MCP tools).
# Found in your Honeycomb URL: https://ui.honeycomb.io/{team}/environments/{environment}/...
HONEYCOMB_TEAM=your-team-slug
HONEYCOMB_ENVIRONMENT=your-environment-slug

# Google OAuth (for Gmail, Calendar, Drive tools)
# Create at: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/oauth/google/callback
# Enable Gmail API: https://console.cloud.google.com/apis/library/gmail.googleapis.com
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=